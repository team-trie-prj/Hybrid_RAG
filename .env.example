# 이 파일을 복사해 .env 로 만들고 실제 키를 채우세요.
#   PowerShell:  Copy-Item .env.example .env
# .env 는 .gitignore 에 의해 절대 커밋되지 않습니다. 따옴표는 없어도 됩니다.

# Gemini 3.1 Flash-Lite 에이전트 (둘 중 하나만 있으면 됨)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# 공공데이터포털(data.go.kr) 인증키 — FR-PUB 연동·인증, 오픈API 400종 카탈로그 수집용.
# 발급: data.go.kr 로그인 → 마이페이지 > 인증키. (Decoding/Encoding 키 모두 가능)
DATAGO_SERVICE_KEY=

# Voyage 임베딩 (voyage-3). 설정 시 ETL 재실행 필요(임베딩 차원 256→1024 재생성).
VOYAGE_API_KEY=

# 선택: Gemini 모델 ID 덮어쓰기 (기본 gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite
